# ==============================================================================
# ⚠️  SECURITY NOTICE - READ BEFORE USING THIS FILE  ⚠️
# ==============================================================================
# This is a TEMPLATE file containing ONLY placeholder values.
# NEVER replace these placeholders with real credentials in this file.
# NEVER commit real API keys, secrets, or credentials to version control.
#
# HOW TO USE:
#   1. Copy this file:  cp sample.env .env
#   2. Open .env and replace each placeholder with your actual value
#   3. Keep .env local — it is listed in .gitignore and must NEVER be committed
#
# If you accidentally expose real credentials:
#   - Immediately revoke/rotate the affected keys from their dashboards
#   - Remove any committed secrets from git history
# ==============================================================================

# Database
MONGOHQ_URL=mongodb://127.0.0.1:27017/freecodecamp?directConnection=true

# Logging
# Get DSN from: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_CLIENT_DSN=
SENTRY_ENVIRONMENT=development

# Auth0 - OAuth 2.0 Credentials
# Get values from: https://manage.auth0.com → Applications → Your App → Settings
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=

# Session, Cookie and JWT encryption strings
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
COOKIE_SECRET=
JWT_SECRET=

# Client Search Bar
# Get values from: https://www.algolia.com → Your App → API Keys
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=

# Stripe
# Get values from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# PayPal
# Get values from: https://developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=

# Patreon
# Get values from: https://www.patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=

# Analytics
# Get values from your GrowthBook dashboard → SDK Connections
GROWTHBOOK_URI=
GROWTHBOOK_FASTIFY_API_HOST=
GROWTHBOOK_FASTIFY_CLIENT_KEY=

# Application paths
HOME_LOCATION=http://localhost:8000
API_LOCATION=http://localhost:3000
FORUM_LOCATION=https://forum.freecodecamp.org
NEWS_LOCATION=https://www.freecodecamp.org/news
RADIO_LOCATION=https://coderadio.freecodecamp.org

# ---------------------
# Build variants
# ---------------------
DEPLOYMENT_ENV=staging
FREECODECAMP_NODE_ENV=development

# Languages to build
CLIENT_LOCALE=english
CURRICULUM_LOCALE=english

# Show or hide WIP in progress challenges
SHOW_UPCOMING_CHANGES=false

# ---------------------
# New API
# ---------------------
FCC_ENABLE_SWAGGER_UI=true
FCC_ENABLE_DEV_LOGIN_MODE=true
FCC_ENABLE_SHADOW_CAPTURE=false
FCC_ENABLE_SENTRY_ROUTES=false
FCC_API_LOG_LEVEL=info
FCC_API_LOG_TRANSPORT=pretty

# Email
# use ses in production
EMAIL_PROVIDER=nodemailer
# SES_ID needs to be empty for now, since the api-server will use SES in testing
# if it is set.
# Get SES credentials from: https://console.aws.amazon.com → IAM → Users → Security credentials
SES_ID=
SES_SECRET=
SES_REGION=us-east-1

# ---------------------
# Client
# ---------------------
# Set to true if the Gatsby schema needs to be updated. E.g. you've added a new
# challenge property. After updating the schema (via pnpm develop) you can
# commit the changed schema and set this back to false.
GATSBY_UPDATE_SCHEMA_SNAPSHOT=false
